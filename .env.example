# ── BASE DE DATOS ────────────────────────────────────────────
POSTGRES_USER=hub_user
POSTGRES_PASSWORD=hub_password
POSTGRES_DB=hub_db
DATABASE_URL=postgresql+asyncpg://hub_user:hub_password@postgres:5432/hub_db
DATABASE_URL_SYNC=postgresql+psycopg2://hub_user:hub_password@postgres:5432/hub_db

# ── LLM ─────────────────────────────────────────────────────
LLM_PROVIDER=ollama                    # ollama | openai | anthropic | groq
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Claves opcionales (solo si se cambia de proveedor)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# ── WHATSAPP META CLOUD API ──────────────────────────────────
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=my_verify_token_here
META_APP_SECRET=

# ── GOOGLE CALENDAR ──────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google_service_account.json
GOOGLE_CALENDAR_ID=

# ── OBSERVABILIDAD ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-assistant-hub

# ── SEGURIDAD ────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_random_64_char_string_in_production
ENCRYPTION_KEY=change_me_to_a_32_char_fernet_key_in_production

# ── GENERACIÓN DE IMÁGENES ───────────────────────────────────
IMAGE_MODEL_ID=runwayml/stable-diffusion-v1-5
IMAGE_OUTPUT_DIR=./storage/generated_images

# ── APLICACIÓN ───────────────────────────────────────────────
ENVIRONMENT=development                # development | production
LOG_LEVEL=INFO
